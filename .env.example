# =============================================
# Aurelia Parfums - Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Get from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/aurelia-db?retryWrites=true&w=majority

# JWT Secret (use a long random string)
JWT_SECRET=demo_jwt_secret_change_me_in_production_xxxxxxxxxxxxxx
JWT_EXPIRES_IN=30d

# Cloudinary (for product images)
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin credentials (change these!)
ADMIN_EMAIL=admin@aurelia.example
ADMIN_PASSWORD=Demo@123456

# Frontend URL (for CORS)
FRONTEND_URL=https://aurelia-frontend-git-main-honerfellow315-ux156.vercel.app
